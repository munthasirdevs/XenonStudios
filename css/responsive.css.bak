/* ============================================
   RESPONSIVE DESIGN (Media Queries)
   ============================================ */

/* ============================================
   MOBILE OPTIMIZATIONS
   Touch targets, fonts, spacing, performance
   ============================================ */

/* Extra Small Phones (< 480px) */
@media (max-width: 479px) {
  /* Prevent horizontal scroll */
  html,
  body {
    overflow-x: hidden !important;
    max-width: 100vw;
  }

  /* Larger touch targets for buttons (min 44px) */
  button,
  a[role="button"],
  .mobile-menu-btn,
  .space-button,
  .service-card-button {
    min-height: 44px;
    min-width: 44px;
    padding: 12px 16px;
  }

  /* Mobile menu links - larger touch areas */
  .mobile-nav-link {
    display: block;
    padding: 16px 20px !important;
    font-size: 18px !important;
    min-height: 52px;
  }

  /* Hero title readable on small screens */
  .hero-title {
    font-size: 32px !important;
    line-height: 1.2;
  }

  .hero-title br {
    display: none;
  }

  /* Navigation compact */
  nav {
    top: 4px;
    width: 96%;
    padding: 0;
  }

  nav .glass-card {
    padding: 10px 14px;
  }

  nav img {
    height: 32px !important;
  }

  /* Mobile menu button larger */
  .mobile-menu-btn {
    padding: 10px !important;
    min-width: 44px;
    min-height: 44px;
  }

  .mobile-menu-btn svg {
    width: 24px;
    height: 24px;
  }

  /* Service cards full width */
  .service-card {
    width: 100%;
    padding: 1.5rem;
    min-height: auto;
  }

  .service-card .text-\[36px\] {
    font-size: 28px;
  }

  .service-card .card_title {
    font-size: 20px;
  }

  /* Pricing cards stack */
  .pricing-card-popular,
  .glass-card {
    padding: 1.5rem !important;
  }

  /* Comparison table scrollable */
  .overflow-x-auto {
    -webkit-overflow-scrolling: touch;
    margin: 0 -0.5rem;
    padding: 0 0.5rem;
  }

  /* Contact cards stack */
  .glass.rounded-xl {
    padding: 1rem !important;
  }

  /* Footer spacing */
  footer .grid {
    gap: 2rem;
  }

  footer h3,
  footer h4 {
    font-size: 18px;
  }

  /* WhatsApp button larger */
  .whatsapp-button {
    padding: 12px 16px;
    font-size: 15px;
    min-height: 48px;
  }

  .whatsapp-button svg {
    width: 20px;
    height: 20px;
  }

  /* Keep animations smooth on mobile - match desktop speed */
  .glow {
    animation-duration: 10s !important;
  }
}

/* Small Phones (480px - 639px) */
@media (min-width: 480px) and (max-width: 639px) {
  .hero-title {
    font-size: 40px !important;
  }

  .mobile-nav-link {
    padding: 14px 18px !important;
    font-size: 17px !important;
    min-height: 50px;
  }

  button,
  .space-button {
    min-height: 44px;
    padding: 12px 20px;
  }
}

/* Tablets (640px - 767px) */
@media (min-width: 640px) and (max-width: 767px) {
  .hero-title {
    font-size: 56px !important;
  }

  #states .grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .mobile-nav-link {
    padding: 14px 18px !important;
    font-size: 17px !important;
  }
}

/* Mobile & Tablet Glow adjustments */
@media (max-width: 768px) {
  .glow {
    width: 60vw;
    height: 60vw;
    max-width: 300px;
    max-height: 300px;
  }

  /* Reduce glow animation on mobile */
  @keyframes glow-pulse {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.5;
    }
  }
}

/* ============================================
   STATES GRID
   ============================================ */
@media (max-width: 639px) {
  #states .grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    padding: 0 0.5rem;
  }
}

@media (min-width: 640px) and (max-width: 1023px) {
  #states .grid {
    grid-template-columns: repeat(2, 1fr);
    padding: 0 1rem;
  }
}

@media (min-width: 1024px) {
  #states .grid {
    grid-template-columns: repeat(4, 1fr);
    padding: 0;
  }
}

/* ============================================
   WHY CHOOSE US & GRID COLUMN OVERRIDES
   ============================================ */
@media (max-width: 639px) {
  .grid-cols-\[1\.5fr_repeat\(5\,1fr\)\] {
    column-gap: 0.25rem !important;
  }

  .hidden-sm {
    display: none;
  }

  /* Prevent text overflow in grids */
  .text-xs {
    font-size: 11px !important;
  }
}

/* ============================================
   FOOTER SECTION
   ============================================ */
@media (min-width: 768px) {
  .footer-column {
    border-bottom: none;
  }

  .footer-content {
    max-height: 500px !important;
    opacity: 1 !important;
  }

  .footer-toggle {
    display: none !important;
  }

  .footer-header {
    cursor: default !important;
  }
}

/* ============================================
   LOADING PERFORMANCE OPTIMIZATIONS
   Reduce heavy effects on mobile
   ============================================ */
@media (max-width: 768px) {
  /* Reduce backdrop-blur on mobile */
  .backdrop-blur-xl {
    --tw-backdrop-blur: blur(12px) !important;
    backdrop-filter: blur(12px) !important;
  }

  .backdrop-blur-2xl {
    --tw-backdrop-blur: blur(16px) !important;
    backdrop-filter: blur(16px) !important;
  }

  /* Optimize shadows */
  .shadow-\[0_0_80px_-16px_rgba\(255\,255\,255\,0\.4\)\,0_20px_60px_rgba\(0\,0\,0\,0\.5\)\] {
    box-shadow:
      0 0 40px -8px rgba(255, 255, 255, 0.3),
      0 10px 30px rgba(0, 0, 0, 0.4) !important;
  }

  /* Reduce table complexity */
  table {
    font-size: 14px;
  }

  .material-symbols-outlined {
    font-size: 24px !important;
  }
}

/* ============================================
   BREAKPOINT SPECIFIC OVERRIDES
   ============================================ */

/* Extra Small (Phones, < 480px) */
@media (max-width: 479px) {
  .stats-card-ray {
    width: 100px !important;
  }

  nav {
    top: 4px;
    width: 95%;
  }

  nav .glass-card {
    padding: 8px 12px;
  }

  nav img {
    height: 32px !important;
  }

  .animated-button {
    margin-left: 0;
  }

  .whatsapp-button {
    padding: 8px 12px;
    font-size: 13px;
  }

  .whatsapp-button svg {
    width: 18px;
    height: 18px;
  }

  .service-card {
    width: 100%;
    padding: 1.5rem;
    min-height: auto;
  }

  .service-card .text-\[36px\] {
    font-size: 28px;
  }

  .service-card .card_title {
    font-size: 22px;
  }

  .service-card-button {
    width: 100%;
    padding: 12px 20px;
    font-size: 14px;
  }

  .stats-card {
    width: 100%;
    max-width: 280px;
    height: auto;
    aspect-ratio: 1 / 0.85;
  }

  .stats-card-inner .text {
    font-size: 3rem;
  }

  .stats-card-inner div.text-lg {
    font-size: 14px;
  }

  h2.text-3xl,
  h2.text-4xl {
    font-size: 28px;
  }

  .grid-cols-\[2fr_repeat\(5\,1fr\)\] {
    grid-template-columns: 1.5fr repeat(5, 0.8fr);
    column-gap: 4px;
  }

  .comparison-table svg {
    width: 14px;
    height: 14px;
  }

  footer .grid {
    gap: 2rem;
  }

  footer h3,
  footer h4 {
    font-size: 16px;
  }

  footer form {
    width: 100%;
  }
}

/* Small (Phones, 480px - 639px) */
@media (max-width: 639px) {
  .stats-card-ray {
    width: 140px !important;
  }

  .hero-title {
    font-size: 40px !important;
    line-height: 1.15;
  }

  nav .glass-card {
    padding: 10px 14px;
  }

  .animated-button {
    margin-left: 0;
    margin-top: 12px;
  }

  .service-card {
    width: 100%;
    padding: 1.5rem;
  }

  .service-card-button {
    width: 100%;
  }

  .stats-card {
    width: 100%;
    max-width: 300px;
    height: auto;
  }

  .why-choose-us {
    display: none;
  }

  .stats-card-inner .text {
    font-size: 3.5rem;
  }

  .grid-cols-\[2fr_repeat\(5\,1fr\)\] {
    grid-template-columns: 1.5fr repeat(5, 1fr);
    column-gap: 8px;
  }

  footer .grid {
    gap: 2.5rem;
  }
}

/* Medium (Tablets, 640px - 767px) */
@media (min-width: 640px) and (max-width: 767px) {
  .hero-title {
    font-size: 56px !important;
  }

  #states .grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .stats-card {
    width: 100%;
    max-width: 280px;
    margin: 0 auto;
  }

  .service-card {
    width: 100%;
    min-height: 480px;
  }

  .grid-cols-\[2fr_repeat\(5\,1fr\)\] {
    grid-template-columns: 1.5fr repeat(5, 1fr);
  }

  footer .grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Large Tablets / Small Laptops (768px - 1023px) */
@media (min-width: 768px) and (max-width: 1023px) {
  .hero-title {
    font-size: 64px !important;
  }

  #states .grid {
    grid-template-columns: repeat(2, 1fr);
    justify-items: center;
  }

  .stats-card {
    width: 100%;
    max-width: 300px;
  }

  .service-card {
    width: 100%;
    min-height: 500px;
  }

  footer .grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Desktops (1024px - 1279px) */
@media (min-width: 1024px) and (max-width: 1279px) {
  .service-card {
    width: 100%;
    min-height: 520px;
  }
}

/* Large Desktops (>= 1280px) */
@media (min-width: 1280px) {
  .hero-title {
    font-size: 80px !important;
  }

  .service-card {
    width: 100%;
    max-width: 380px;
  }
}

/* Height specific overrides */
@media (max-height: 700px) {
  #home {
    padding-top: 7rem;
    padding-bottom: 3rem;
    min-height: auto;
  }

  .hero-title {
    margin-bottom: 1rem;
  }

  nav {
    top: 8px;
  }
}

/* ============================================
   PRINT OVERRIDES
   ============================================ */
@media print {
  nav,
  .mobile-menu,
  .glow,
  .grid-bg,
  button,
  .service-card-button,
  .explore-button,
  .animated-button,
  .quiz-cta-button {
    display: none !important;
  }

  body {
    background: white;
    color: black;
  }

  .service-card {
    break-inside: avoid;
  }
}

/* ============================================
   QUIZ CTA BUTTON - MOBILE
   ============================================ */
@media (max-width: 768px) {
  .quiz-cta-button {
    padding: 12px 20px;
    font-size: 0.9rem;
    width: 100%;
    max-width: 280px;
    justify-content: center;
  }

  .quiz-badge {
    font-size: 0.65rem;
  }
}
